$(if $(TARGET),,$(error TARGET is not defined))

INSTALL_DIR ?= $(PWD)/install_dir/$(BUILD_TYPE)
BUILD_DIR ?= $(PWD)/build_dir/$(BUILD_TYPE)

INSTALL_BIN_DIR ?= $(INSTALL_DIR)/bin
OBJ_DIR = $(BUILD_DIR)/$(TARGET)/obj


OBJS = $(CSRCS:.c=.o) 
OBJS += $(CXXSRCS:.cpp=.o) 
OBJS += $(ASMSRCS:.s=.o)
DST_OBJS = $(addprefix $(OBJ_DIR)/, $(OBJS))

TARGETS = $(OBJ_DIR)/$(TARGET).elf
TARGETS += $(OBJ_DIR)/$(TARGET).bin
TARGETS += $(OBJ_DIR)/$(TARGET).lst
TARGETS += $(OBJ_DIR)/$(TARGET).hex
ifdef STACK_USAGE
	TARGETS += $(OBJ_DIR)/$(TARGET).stack_usage
endif

LDFLAGS += -Wl,-M=$(OBJ_DIR)/$(TARGET).map

.PRECIOUS: $(DST_OBJS)

all:: $(TARGET_EXTRA_DEPS) $(DST_OBJS) $(TARGETS)
	echo $(TARGETS)

$(OBJ_DIR)/%.elf: $(DST_OBJS)
	$(CC) $^ $(LDFLAGS) -o $@ 

$(OBJ_DIR)/%.stack_usage : $(DST_OBJS)
	$(AVSTACK) $^ > $@ 

$(OBJ_DIR)/%.o: %.c
	mkdir -p "$(OBJ_DIR)/`dirname $<`"
	$(CC) $(CFLAGS) -o $@ -c $<  -D__TLOG_FILE__=\"$(shell basename $< .c)\"

$(OBJ_DIR)/%.o: %.cpp
	mkdir -p "$(OBJ_DIR)/`dirname $<`"
	$(CC) $(CXXFLAGS) -o $@ -c $<  -D__TLOG_FILE__=\"$(shell basename $< .cpp)\"

$(OBJ_DIR)/%.o: %.s
	mkdir -p "$(OBJ_DIR)/`dirname $<`"
	$(AS) $(ASMFLAGS) -o $@ -c $<

# some object files dont consume stack so no .su file is generated by GCC
# avstack.pl expects however that for each .o there is .su
ifdef STACK_USAGE
$(OBJ_DIR)/%.su: $(DST_OBJS)
	touch $<
endif

$(OBJ_DIR)/%.lst: $(OBJ_DIR)/$(TARGET).elf
	$(OBJDUMP) -htS $< > $@

$(OBJ_DIR)/%.hex: $(OBJ_DIR)/$(TARGET).elf
	$(OBJCOPY) --output-target=ihex $(OBJCP_FLAGS) $< $@

$(OBJ_DIR)/%.bin: $(OBJ_DIR)/$(TARGET).elf
	$(OBJCOPY) $(OBJCP_FLAGS) $< $@
	$(SIZE) --format=avr --mcu=$(MCU) $<

write_flash: $(OBJ_DIR)/$(TARGET).hex
	avrdude -p atmega328p -P usb -c $(AVRDUDE_PROGRAMMER) -U flash:w:$<

read_eeprom:
	avrdude -p atmega328p -P usb -c $(AVRDUDE_PROGRAMMER) -U eeprom:r:eeprom.hex:i

read_flash:
	avrdude -p atmega328p -P usb -c $(AVRDUDE_PROGRAMMER) -U flash:r:flash.hex:i

read_fuses:
	avrdude -p atmega328p -P usb -c $(AVRDUDE_PROGRAMMER) -U lfuse:r:-:h -U hfuse:r:-:h -U efuse:r:-:h

write_default_16MHz_fuses:
	avrdude -p atmega328p -P usb -c $(AVRDUDE_PROGRAMMER) \
    -U lfuse:w:0xFF:m \
    -U hfuse:w:0x93:m \
    -U efuse:w:0xFF:m \
    -U lock:w:0xFF:m
